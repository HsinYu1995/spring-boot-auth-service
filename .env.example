# Database
DB_USERNAME=postgres
DB_PASSWORD=changeme

# Mail (use Gmail App Password, not your login password)
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your@gmail.com

# Prod only — base URL where the app is hosted
APP_BASE_URL=http://localhost

# Allowed CORS origin (standalone docker-compose.yml and docker-compose.prod.yml)
# Use http://localhost for prod compose (nginx serves on port 80)
# Use http://localhost:3000 or similar for standalone docker-compose.yml
CORS_ALLOWED_ORIGIN=http://localhost
